# ─── Sentinel environment template ──────────────────────────────────────────────
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# All variables MUST be set; missing required ones cause the server to refuse to start.

# ─── Server ─────────────────────────────────────────────────────────────────────
APP_ENV=development                       # development | staging | production
APP_PORT=8081
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:8081
FRONTEND_ORIGIN=http://localhost:5180
LOG_LEVEL=info                            # debug | info | warn | error
LOG_FORMAT=json                           # json | console

# ─── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=sentinel-dev
MYSQL_DATABASE=sentinel
MYSQL_TEST_DATABASE=sentinel_test
MYSQL_MAX_OPEN_CONNS=25
MYSQL_MAX_IDLE_CONNS=5
MYSQL_CONN_MAX_LIFETIME=300               # seconds

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TEST_DB=15

# ─── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-please
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h                     # 7 days
BCRYPT_COST=12

# ─── AI / LLM (Phase 4+) ──────────────────────────────────────────────────────
AI_ENABLED=true                           # master switch; false hides all AI UI + 503s AI endpoints
AI_PROVIDER=mock                          # mock (default, zero cost) | noop | anthropic | openai
AI_MODEL_ATTRIBUTOR=claude-3-5-sonnet-latest
AI_MODEL_COMPLETER=claude-3-5-sonnet-latest
AI_MODEL_PRIORITIZER=claude-3-5-haiku-latest
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_DAILY_LIMIT_USD=5.00
AI_MONTHLY_LIMIT_USD=100.00
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.0                        # 0.0 = deterministic (recommended for testing); 0.7–1.0 for creative tasks
AI_TIMEOUT_SECONDS=30
AI_CACHE_TTL_SECONDS=3600

# ─── Mock server ───────────────────────────────────────────────────────────────
MOCK_DEFAULT_DELAY_MS=0
MOCK_RECORD_HITS=true
MOCK_BODY_TRUNCATE_BYTES=8192

# ─── Test runner ───────────────────────────────────────────────────────────────
RUNNER_DEFAULT_TIMEOUT_SECONDS=30
RUNNER_DEFAULT_MODE=sequential            # sequential | parallel
RUNNER_DEFAULT_CONCURRENCY=1
RUNNER_MAX_CONCURRENCY=16

# ─── Rate limiting (Redis token bucket) ────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPM=600                       # requests per minute per user
RATE_LIMIT_BURST=100

# ─── Observability ─────────────────────────────────────────────────────────────
ENABLE_PROMETHEUS=true
PROMETHEUS_PATH=/metrics
SENTRY_DSN=
